# Copy to .env (gitignored) and fill in real values. Never commit the real .env.

# LocalStack Hobby-plan auth token — from app.localstack.cloud, Account/Tokens.
# Must be a Hobby-plan token; freemium/default tokens also work since Hobby *is*
# the freemium tier, but ECS/ECR will still be unavailable either way (see NOTES.md).
LOCALSTACK_AUTH_TOKEN=

# Fine-grained GitHub PAT scoped to ONLY the app-repo and gitops-repo, with
# Contents: Read & Write and Pull requests: Read & Write. Used by:
#   - Argo CD, to read the private gitops-repo
#   - Jenkins, to push a branch and open a PR against gitops-repo (and to check
#     out the private app-repo)
GITOPS_PR_PAT=

# Password for the Jenkins "admin" account, seeded via Configuration as Code.
JENKINS_ADMIN_PASSWORD=
